ol-auto\">\r\n                            <label><input type=\"checkbox\" id=\"C-5\">C-5</label>\r\n                            </div>\r\n                            <div class=\"col-auto\">\r\n                            <label><input type=\"checkbox\" id=\"C-7\">C-7</label>\r\n                            </div>\r\n                            <div class=\"col-auto\">\r\n                            <label><input type=\"checkbox\" id=\"C-8\">C-8</label>\r\n                            </div>\r\n                            <div class=\"col-auto\">\r\n                            <label><input type=\"checkbox\" id=\"C-9\">C-9</label>\r\n                            </div>\r\n                            <div class=\"col-auto\">\r\n                            <label><input type=\"checkbox\" id=\"C-10\">C-10</label>\r\n                            </div>\r\n                            <div class=\"col-auto\">\r\n                            <label><input type=\"checkbox\" id=\"CIVIS\">CIVIS</label>\r\n                            </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!--Severity-->\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-auto\">\r\n\r\n                        <label class=\"form-label\" for=\"severity\">Severidad:</label>\r\n                        <select class=\"form-control\" id=\"severity\">\r\n                            <option value=\"Leve\" selected>Leve</option>\r\n                            <option value=\"Moderado\">Moderado</option>\r\n                            <option value=\"Serio\">Serio</option>\r\n                            <option value=\"Critico\">Crítico</option>\r\n                        </select>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!--Type-->\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-auto\">\r\n\r\n                        <label class=\"form-label\" for=\"type\">Tipo:</label>\r\n                        <select class=\"form-control\" id=\"type\">\r\n                            <option value=\"Mantenimiento\" selected>Mantenimiento</option>\r\n                            <option value=\"Accidente\">Accidente</option>\r\n                            <option value=\"Otro\">Otro</option>\r\n                        </select>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!--Description-->\r\n\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-10\">\r\n                        <label class=\"form-label\" for=\"descrpition\">Describa la incidencia:</label>\r\n                        <input type=\"text\" class=\"form-control\" id=\"description\" placeholder=\"Descripción\" required>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!--Image-->\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-auto\">\r\n                        <label class=\"form-label\" for=\"image\">Introduzca una fotografía de la incidencia (opcional):</label>\r\n\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-auto\">\r\n                        <input type=\"file\" class=\"form-control-file\" id=\"image\">\r\n\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            \r\n            <!--Button row-->\r\n            <div class=\"row\">\r\n                <div class=\"d-flex justify-content-center gap-3 mb-4\">\r\n                    <div class=\"col-auto\">\r\n                        <button type=\"submit\" class=\"btn btn-primary\">Confirmar</button>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            </div>\r\n\r\n\r\n            </div>\r\n\r\n\r\n\r\n\r\n\r\n        </form>\r\n\r\n\r\n    </main>\r\n\r\n    <!-- Footer -->\r\n    <div id=\"_footer\"></div>\r\n</body>\r\n\r\n<script src=\"../js/js_slider.js\"></script>\r\n<script>\r\n    // Cargamos el contenido de _header.html\r\n    fetch('./partials/_header.html')\r\n        .then(response => response.text())\r\n        .then(data => {\r\n            // Lo inyectamos en el div que creamos arriba\r\n            document.getElementById('_header').innerHTML = data;\r\n        })\r\n        .catch(error => console.error('Error al cargar el header:', error));\r\n</script>\r\n<script>\r\n    // Cargamos el contenido de _footer.html\r\n    fetch('./partials/_footer.html')\r\n        .then(response => response.text())\r\n        .then(data => {\r\n            // Lo inyectamos en el div que creamos arriba\r\n            document.getElementById('_footer').innerHTML = data;\r\n        })\r\n        .catch(error => console.error('Error al cargar el footer:', error));\r\n</script>\r\n\r\n</html>
