enter mt-5 ms-5\">\r\n            <div class=\"col-12\">\r\n                <h2>Mapa de calor de incidencias por líneas y tiempo</h2>\r\n                <p>Muestra en un mapa de calor las incidencias por linea en un rango de tiempo determinado</p>\r\n            </div>\r\n        </div>\r\n\r\n\r\n        <script src=\"https://code.highcharts.com/highcharts.js\"></script>\r\n        <script src=\"https://code.highcharts.com/modules/heatmap.js\"></script>\r\n        <script src=\"https://code.highcharts.com/modules/exporting.js\"></script>\r\n        <script src=\"https://code.highcharts.com/modules/export-data.js\"></script>\r\n        <script src=\"https://code.highcharts.com/modules/accessibility.js\"></script>\r\n        <script src=\"https://code.highcharts.com/themes/adaptive.js\"></script>\r\n\r\n        <figure class=\"highcharts-figure\">\r\n            <div id=\"container\"></div>\r\n        </figure>\r\n\r\n\r\n    </main>\r\n\r\n    <!-- Footer -->\r\n    <div id=\"_footer\"></div>\r\n\r\n</body>\r\n\r\n<script type=\"module\" src=\"../../resources/js/pages/incidencies.js\"></script>\r\n\r\n<script src=\"../../resources/js/components/heatmap.js\"></script>\r\n</html>
