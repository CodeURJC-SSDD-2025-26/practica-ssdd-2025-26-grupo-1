<+><!DOCTYPE html>\r\n<html lang=\"es\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Partial de bootstrap</title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"../static/css/style.css\">\r\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js\"></script>\r\n</head>\r\n\r\n<body>\r\n    <!--HEADER-->\r\n    <div id=\"_header\"></div>\r\n\r\n    <main class=\"container-main\">\r\n\r\n        <form role=\"form\" action=\"admin_panel.html\" target=\"_blank\">\r\n\r\n            <!--Lines-->\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <h2>Añadir línea</h2>\r\n                </div>\r\n            </div>\r\n            </div>\r\n\r\n            <!--Name-->\r\n\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-10\">\r\n                        <label class=\"form-label\" for=\"name\">Indique el nombre de la línea:</label>\r\n                        <input type=\"text\" class=\"form-control\" id=\"name\" placeholder=\"Nombre\" required>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n\r\n            <!--Location-->\r\n\r\n            <div class=\"row\">\r\n                <div class=\"d-flex flex-wrap justify-content-center gap-3 mb-4\">\r\n                    <div class=\"form-group col-10\">\r\n                        <label class=\"form-label\" for=\"location\">Indique la ubicación de la línea:</label>\r\n                        <input type=\"text\" class=\"form-control\" id=\"location\" placeholder=\"Ubicación\" required>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n\r\n            <!--Button row-->\r\n            <div class=\"row\">\r\n                <div class=\"d-flex justify-content-center gap-3 mb-4\">\r\n                    <div class=\"col-auto\">\r\n                        <button type=\"submit\" class=\"btn btn-primary\">Confirmar</button>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            </div>\r\n            </div>\r\n        </form>\r\n\r\n    </main>\r\n\r\n    <!-- Footer -->\r\n    <div id=\"_footer\"></div>\r\n</body>\r\n\r\n<script src=\"../js/js_slider.js\"></script>\r\n<script>\r\n    // Cargamos el contenido de _header.html\r\n    fetch('./partials/_header.html')\r\n        .then(response => response.text())\r\n        .then(data => {\r\n            // Lo inyectamos en el div que creamos arriba\r\n            document.getElementById('_header').innerHTML = data;\r\n        })\r\n        .catch(error => console.error('Error al cargar el header:', error));\r\n</script>\r\n<script>\r\n    // Cargamos el contenido de _footer.html\r\n    fetch('./partials/_footer.html')\r\n        .then(response => response.text())\r\n        .then(data => {\r\n            // Lo inyectamos en el div que creamos arriba\r\n            document.getElementById('_footer').innerHTML = data;\r\n        })\r\n        .catch(error => console.error('Error al cargar el footer:', error));\r\n</script>\r\n\r\n</html>
